# GitOps Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to Git!

# Cloudflare Credentials
# Required for: cert-manager (DNS01 challenge) and external-dns
# Token needs: Zone:Read and DNS:Edit permissions
CLOUDFLARE_API_TOKEN=""

# Cloudflare R2 Credentials
# Required for: CNPG (PostgreSQL) backups
S3_ACCESS_KEY_ID=""
S3_ACCESS_KEY_SECRET=""


# Infisical Authentication
# Required for: Application secret management
INFISICAL_CLIENT_ID=""
INFISICAL_CLIENT_SECRET=""

# GitHub Personal Access Token
# Required for: Flux bootstrap
# Token needs: Full repo permissions
GITHUB_TOKEN=""

# GitHub Configuration
GITHUB_USER=""
GITHUB_REPO=""
